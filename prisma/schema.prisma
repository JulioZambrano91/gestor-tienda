// Prisma Schema para Gestor de Tienda Local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  costPrice   Float
  salePrice   Float
  stock       Int      @default(0)
  imageUrl    String?
  
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  
  saleItems   SaleItem[]
}

model Sale {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  totalAmount Float
  totalProfit Float
  paymentType String     // "CONTADO" o "FIADO"
  
  customerId  Int?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  
  items       SaleItem[]
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  quantity    Int
  priceAtSale Float
  
  saleId      Int
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
}

model Customer {
  id          Int           @id @default(autoincrement())
  name        String
  phone       String?
  totalOwed   Float         @default(0.0) // Deuda total acumulada
  
  sales       Sale[]
  payments    DebtPayment[]
}

model DebtPayment {
  id          Int      @id @default(autoincrement())
  amount      Float
  createdAt   DateTime @default(now())
  concept     String?  // "Abono", "Saldado"
  
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}
