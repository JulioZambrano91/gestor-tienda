// Prisma Schema para Gestor de Tienda Local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  costPrice   Float    // Costo unitario promedio ponderado
  salePrice   Float    // Precio de venta por unidad
  stock       Int      @default(0)
  imageUrl    String?

  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])

  saleItems       SaleItem[]
  stockMovements  StockMovement[]
}

model StockMovement {
  id          Int      @id @default(autoincrement())
  type        String   // "ENTRADA" | "SALIDA_VENTA"
  quantity    Int
  totalCost   Float    // total pagado en ese lote (para ENTRADA)
  unitCost    Float    // costo unitario de ese lote
  note        String?  // ej: "Compra 12 bultos Harina PAN"
  createdAt   DateTime @default(now())

  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Sale {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  totalAmount Float
  totalProfit Float
  paymentType   String   // "CONTADO" o "FIADO"
  paymentMethod String   @default("EFECTIVO") // "EFECTIVO", "PAGO_MOVIL", "PUNTO_VENTA", "FIADO"

  customerId  Int?
  customer    Customer?  @relation(fields: [customerId], references: [id])

  items       SaleItem[]
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  quantity    Int
  priceAtSale Float
  
  saleId      Int
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
}

model Customer {
  id          Int           @id @default(autoincrement())
  name        String
  phone       String?
  totalOwed   Float         @default(0.0) // Deuda total acumulada
  
  sales       Sale[]
  payments    DebtPayment[]
  expenses    Expense[]
}

model DebtPayment {
  id          Int      @id @default(autoincrement())
  amount      Float
  createdAt   DateTime @default(now())
  concept     String?  // "Abono", "Saldado"

  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Expense {
  id        Int      @id @default(autoincrement())
  amount    Float
  concept   String
  category  String   @default("OTRO")   // "COMPRA", "RETIRO", "SERVICIO", "PRESTAMO", "OTRO"
  account   String   @default("EFECTIVO") // "EFECTIVO", "PAGO_MOVIL", "PUNTO_VENTA"
  createdAt DateTime @default(now())

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])
}
